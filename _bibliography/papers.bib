@inproceedings{ballegeer2026fovnet,
  abbr      = {CVPR},
  bibtex_show = {true},
  title     = {FoV-Net: Rotation-Invariant CAD B-rep Learning via Field-of-View Ray Casting},
  author    = {Ballegeer, Matteo and Benoit, Dries F.},
  booktitle = {IEEE/CVF International Conference on Computer Vision and Pattern Recognition},
  year      = {2026},
  month     = {June},
  address   = {Denver, Colorado},
  arxiv     = {2602.24084},
  abstract  = {Learning directly from boundary representations (B-reps) has significantly advanced 3D CAD analysis. However, state-of-the-art B-rep learning methods rely on absolute coordinates and normals to encode global context, making them highly sensitive to rotations. We introduce FoV-Net, the first B-rep learning framework that captures both local surface geometry and global structural context in a rotation-invariant manner using field-of-view ray casting.},
  selected  = {true}
}

@article{ballegeer2026bendfm,
  abbr      = {JIM},
  bibtex_show = {true},
  title     = {BenDFM: A taxonomy and synthetic CAD dataset for manufacturability assessment in sheet metal bending},
  author    = {Ballegeer, Matteo and Benoit, Dries F.},
  journal   = {Journal of Intelligent Manufacturing},
  year      = {2026},
  arxiv     = {2603.13102},
  abstract  = {Predicting the manufacturability of CAD designs early is crucial for Design for Manufacturing. We propose a taxonomy of manufacturability metrics and introduce BenDFM, the first synthetic dataset for manufacturability assessment in sheet metal bending with 20,000 parts, both manufacturable and unmanufacturable, generated with process-aware bending simulations.},
  note      = {Accepted},
  selected  = {true}
}

